# Shared JWT secret used by NestJS to sign standard HS256 tokens
JWT_SECRET=test_secret

# Next.js frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# NestJS API base URL
NESTJS_API_URL=http://localhost:3001/api

# Mimo OpenAI-compatible endpoint
MIMO_API_URL=http://localhost:3002

# Mimo API key
MIMO_API_KEY=test_key

# Model identifier
MIMO_MODEL_NAME=mimo

# Enable LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=flight-booking-chatbot

# Agent service port
AGENT_PORT=3002

# Constraints & Limits
MAX_MESSAGE_LENGTH=10000
MEMORY_WINDOW_SIZE=20
MEMORY_TOKEN_BUDGET=4000
QUEUE_MAX_DEPTH=3
